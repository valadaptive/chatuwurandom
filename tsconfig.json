{
	"compilerOptions": {
		"noImplicitAny": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"moduleResolution": "Bundler",
		"sourceMap": true,
		"strictNullChecks": true,
		"resolveJsonModule": true,
		"strict": true,
		"module": "ES2022",
		"composite": true,
		"jsx": "preserve",
		"jsxImportSource": "preact",
		"target": "es2020",
		"noErrorTruncation": true,
		"outDir": "build",
		"lib": ["es2021", "WebWorker", "DOM"],
		"baseUrl": ".",
		"paths": {
			"uwurandom": ["./uwurandom/uwurandom-js/dist/uwurandom.d.mts"]
		}
	},
	"include": [
		"src/**/*",
		"test/**/*.test.ts"
	]
}
